{
  "name": "LRCLIB",
  "author": "Jorge Pardo",
  "version": "4.0.0",
  "description": "Fetch lyrics from LRCLIB",
  "website": "https://github.com/J0R6IT0/navidrome-lrclib-plugin",
  "permissions": {
    "http": {
      "reason": "To fetch lyrics from the internet",
      "requiredHosts": ["lrclib.net", "api.lyrics.ovh"]
    },
    "library": {
      "reason": "To save lyrics as .lrc files",
      "filesystem": true
    },
    "cache": {
      "reason": "To cache lyrics."
    }
  },
  "config": {
    "schema": {
      "type": "object",
      "properties": {
        "lyricsMode": {
          "type": "string",
          "title": "Lyrics mode",
          "default": "both_prioritize_synced",
          "oneOf": [
            {
              "const": "both_prioritize_synced",
              "title": "Both (prioritize synchronized)"
            },
            {
              "const": "both_prioritize_plain",
              "title": "Both (prioritize plain)"
            },
            {
              "const": "synced_only",
              "title": "Synchronized only"
            },
            {
              "const": "plain_only",
              "title": "Plain only"
            }
          ]
        },
        "lyricsovh": {
          "type": "boolean",
          "title": "Fallback to lyrics.ovh (plain)",
          "default": true
        },
        "enableCache": {
          "type": "boolean",
          "title": "Cache lyrics in memory (compressed)",
          "default": true
        },
        "cacheTtl": {
          "type": "number",
          "title": "Cache TTL seconds",
          "default": 86400,
          "description": "Time (in seconds) that cached lyrics remain valid."
        },
        "writeLyrics": {
          "type": "boolean",
          "title": "Write lyrics to .lrc files",
          "default": false
        },
        "updateLyrics": {
          "type": "boolean",
          "title": "Update existing .lrc files",
          "default": false
        }
      }
    },
    "uiSchema": {
      "type": "VerticalLayout",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/lyricsMode",
          "options": {
            "format": "radio"
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/lyricsovh",
          "rule": {
            "effect": "HIDE",
            "condition": {
              "scope": "#/properties/lyricsMode",
              "schema": { "const": "synced_only" }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/enableCache"
        },
        {
          "type": "Control",
          "scope": "#/properties/cacheTtl",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/enableCache",
              "schema": { "const": true }
            }
          }
        },
        {
          "type": "Control",
          "scope": "#/properties/writeLyrics"
        },
        {
          "type": "Label",
          "text": "NOTE: Your music library must be mounted with write access and the plugin must have permission to write files."
        },
        {
          "type": "Control",
          "scope": "#/properties/updateLyrics",
          "rule": {
            "effect": "SHOW",
            "condition": {
              "scope": "#/properties/writeLyrics",
              "schema": { "const": true }
            }
          }
        }
      ]
    }
  }
}
